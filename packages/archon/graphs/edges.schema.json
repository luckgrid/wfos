{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/archon/graphs/edges.schema.json",
  "title": "Archon project graph",
  "description": "The generated relationship graph: nodes (units, capabilities, policies, actors) and directed edges between them. Canon: lg_wfos_lvl_0_metadata_plane.md §10.5. Generated by `archon sync` into registry/graph.json (host-specific, gitignored).",
  "type": "object",
  "required": ["nodes", "edges"],
  "additionalProperties": true,
  "properties": {
    "generated_at": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "native-substrate",
              "workspace",
              "package",
              "app",
              "capability",
              "policy",
              "actor",
              "profile"
            ]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "rel", "to"],
        "additionalProperties": true,
        "properties": {
          "from": { "type": "string" },
          "rel": {
            "type": "string",
            "enum": [
              "provides",
              "requires",
              "uses",
              "governed-by",
              "blocked-by",
              "packaged-by",
              "runs-on",
              "selects"
            ]
          },
          "to": { "type": "string" }
        }
      }
    }
  }
}
