#!/usr/bin/env bash
# archon sync — generate the registry from descriptors, policies, and the .agents layer.
# Reads sources (descriptors/policies/tools.json/.agents) and writes only generated output
# under registry/ (and, from E04.S3, .agents/tools/local-toolkit.yml). Agent-safe: no
# install, no secret read, no dotfile edit.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/descriptor.sh
source "$_self/../lib/descriptor.sh"
# shellcheck source=../lib/registry.sh
source "$_self/../lib/registry.sh"

archon_require_jq
mkdir -p "$ARCHON_REGISTRY"

archon_info "archon sync — generating registry"

archon_emit_units    > "$ARCHON_REGISTRY/units.json"
archon_emit_skills   > "$ARCHON_REGISTRY/skills.json"
archon_emit_profiles > "$ARCHON_REGISTRY/profiles.json"
archon_emit_policies > "$ARCHON_REGISTRY/policies.json"

u=$(jq -r '.summary.total' "$ARCHON_REGISTRY/units.json")
p=$(jq -r '.policies | length' "$ARCHON_REGISTRY/policies.json")
s=$(jq -r '.skills | length' "$ARCHON_REGISTRY/skills.json")
pr=$(jq -r '.profiles | length' "$ARCHON_REGISTRY/profiles.json")

archon_ok "units.json    ($u units)"
archon_ok "policies.json ($p policies)"
archon_ok "skills.json   ($s skills)"
archon_ok "profiles.json ($pr profiles)"

# Graph: derive relationships from units + policies (must run after units/policies are written).
if archon_emit_graph > "$ARCHON_REGISTRY/graph.json" 2>/dev/null; then
  gn=$(jq -r '.nodes | length' "$ARCHON_REGISTRY/graph.json")
  ge=$(jq -r '.edges | length' "$ARCHON_REGISTRY/graph.json")
  archon_emit_graph_dot < "$ARCHON_REGISTRY/graph.json" > "$ARCHON_REGISTRY/graph.dot"
  archon_ok "graph.json    ($gn nodes, $ge edges)"
  archon_ok "graph.dot     -> registry/graph.dot"
else
  archon_warn "graph not generated (units.json or policies.json missing)"
fi

if [ -f "$ARCHON_REGISTRY/tools.json" ]; then
  t=$(jq -r '.summary.total' "$ARCHON_REGISTRY/tools.json" 2>/dev/null || echo "?")
  archon_info "tools.json present ($t tools — produced by 'dust doctor')"
else
  archon_warn "tools.json absent — run 'dust doctor' (or 'moon run dust:doctor') to produce it"
fi

# .agents/ navigation view: the local toolkit list (present/missing/candidate/deprecated).
if [ -f "$ARCHON_REGISTRY/tools.json" ]; then
  mkdir -p "$AGENTS_HOME/tools"
  archon_emit_local_toolkit > "$AGENTS_HOME/tools/local-toolkit.yml" \
    && archon_ok "local-toolkit.yml ($(grep -c '^  - ' "$AGENTS_HOME/tools/local-toolkit.yml") tools) -> .agents/tools/"
fi

# Manifest beside generated registry outputs (E08.S2).
_sync_outputs=(units.json skills.json profiles.json policies.json)
[ -f "$ARCHON_REGISTRY/graph.json" ] && _sync_outputs+=(graph.json graph.dot)
archon_emit_manifest \
  --id "archon-sync-$(date -u +%Y%m%d-%H%M%S)" \
  --workflow "archon-sync" \
  --source "descriptors+policies+profiles+skills" \
  --tool "archon" \
  --retention "review-before-delete" \
  --notes "Generated by archon sync; host-specific registry outputs." \
  "${_sync_outputs[@]}" > "$ARCHON_REGISTRY/manifest.json"
archon_ok "manifest.json  -> registry/manifest.json"
