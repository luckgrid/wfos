#!/usr/bin/env bash
# archon-gitleaks — report-only secret scan (gitleaks 8.x). Agent-safe: it scans, it never writes
# to tracked files, stages nothing, and performs no remote operation. Modes:
#   detect          gitleaks git         (whole-repo, history-aware — the periodic scan routine)
#   staged          gitleaks git --staged (the pre-commit hook path)
#   dir <path>      gitleaks dir <path>  (scan a directory/fixture that is not a git repo)
# A finding is reported with file + line and the command exits non-zero.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"

usage() {
  cat <<EOF
archon-gitleaks — report-only secret scan (gitleaks)

usage:
  archon secrets-scan [detect|staged|dir <path>] [-- <extra gitleaks args>]

detect        whole-repo history-aware scan (default; the periodic scan-report routine)
staged        scan staged changes only (the pre-commit hook path)
dir <path>    scan a directory or file that is not a git repo (fixtures, exports)

Reads .gitleaks.toml at the workspace root when present. Report-only: no writes, no remote ops.
EOF
}

main() {
  command -v gitleaks >/dev/null 2>&1 \
    || archon_die "gitleaks not found (Dust 'secrets' module) — install to run the secret scan"

  local mode="${1:-detect}"; shift || true
  local cfg="$WFOS_ROOT/.gitleaks.toml"
  local -a args=(--redact --verbose)
  [ -f "$cfg" ] && args+=(--config "$cfg")

  case "$mode" in
    detect) set -- git "${args[@]}" "$@" "$WFOS_ROOT" ;;
    staged) set -- git --staged "${args[@]}" "$@" "$WFOS_ROOT" ;;
    dir)
      local path="${1:-}"; shift || true
      [ -n "$path" ] || archon_die "usage: archon secrets-scan dir <path>"
      set -- dir "${args[@]}" "$@" "$path"
      ;;
    help|-h|--help) usage; return 0 ;;
    *) archon_err "unknown mode: $mode"; echo; usage; return 1 ;;
  esac

  archon_info "gitleaks $1 (mode: $mode)"
  if gitleaks "$@"; then
    archon_ok "no leaks found"
    return 0
  else
    archon_err "gitleaks reported findings (see file:line above) — commit blocked"
    return 1
  fi
}

main "$@"
