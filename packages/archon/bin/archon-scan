#!/usr/bin/env bash
# archon-scan — read-only polyrepo scan report over Build/src/workspaces. Writes registry/scan.json
# (machine) and registry/SCAN.md (RTK-compressible human table). One report replaces N per-repo
# `git status` reads. Agent-safe: read-only `git -C <dir>` + descriptor reads; no writes outside
# registry/, no remote operations. See schemas/scan.schema.json.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/descriptor.sh
source "$_self/../lib/descriptor.sh"
# shellcheck source=../lib/registry.sh
source "$_self/../lib/registry.sh"

archon_require_jq
mkdir -p "$ARCHON_REGISTRY"

archon_info "archon scan — read-only polyrepo report ($WORKSPACES_DIR)"

archon_emit_scan > "$ARCHON_REGISTRY/scan.json"

# SCAN.md: human projection, one row per workspace.
{
  printf '# Workspace scan report\n\n'
  # shellcheck disable=SC2016  # literal backticks for the generated markdown note
  printf 'GENERATED by `archon scan` (read-only). Regenerate: `moon run archon:scan`. Host-specific (gitignored).\n\n'
  printf 'generated_at: %s\n\n' "$(jq -r '.generated_at' "$ARCHON_REGISTRY/scan.json")"
  printf 'summary: %s workspace(s) — %s clean, %s dirty\n\n' \
    "$(jq -r '.summary.total' "$ARCHON_REGISTRY/scan.json")" \
    "$(jq -r '.summary.clean' "$ARCHON_REGISTRY/scan.json")" \
    "$(jq -r '.summary.dirty' "$ARCHON_REGISTRY/scan.json")"
  printf '| path | kind | branch | default | status | remotes | manifests |\n'
  printf '|------|------|--------|---------|--------|---------|-----------|\n'
  jq -r '.workspaces[] |
    "| \(.path) | \(.kind) | \(.active_branch // "-") | \(.default_branch // "-") | \(.worktree_status.state) (\(.worktree_status.changed)) | \((.remote_set | join(","))) | \((.native_manifests | join(","))) |"' \
    "$ARCHON_REGISTRY/scan.json"
} > "$ARCHON_REGISTRY/SCAN.md"

n=$(jq -r '.summary.total' "$ARCHON_REGISTRY/scan.json")
c=$(jq -r '.summary.clean' "$ARCHON_REGISTRY/scan.json")
d=$(jq -r '.summary.dirty' "$ARCHON_REGISTRY/scan.json")
archon_ok "scan.json     ($n workspaces: $c clean, $d dirty)"
archon_ok "SCAN.md       -> registry/SCAN.md"

# Manifest beside generated scan outputs (E08.S2). Overwrites registry/manifest.json
# with the latest Archon run contract (sync or scan — whichever ran last).
archon_emit_manifest \
  --id "archon-scan-$(date -u +%Y%m%d-%H%M%S)" \
  --workflow "archon-scan" \
  --source "$WORKSPACES_DIR" \
  --tool "archon" \
  --retention "review-before-delete" \
  --notes "Generated by archon scan; host-specific polyrepo report." \
  scan.json SCAN.md > "$ARCHON_REGISTRY/manifest.json"
archon_ok "manifest.json -> registry/manifest.json"
