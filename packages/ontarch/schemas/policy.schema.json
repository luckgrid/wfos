{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/policy.schema.json",
  "title": "Ontarch policy",
  "description": "Machine-readable policy: allowed and blocked behavior, gates, and agent rails. Canon: lg_wfos_lvl_0_metadata_plane.md §10.4. Permissive by design — it accepts both the agent-rails style ([agent] allow/block, [gates], [secrets]) and the command style ([block]/[allow] commands/tools).",
  "type": "object",
  "required": ["id", "version"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "applies_to": { "type": "string" },
    "version": { "type": "string" },
    "agent": {
      "type": "object",
      "properties": {
        "env_flag": { "type": "string" },
        "allow": { "type": "array", "items": { "type": "string" } },
        "block": { "type": "array", "items": { "type": "string" } }
      }
    },
    "block": {
      "type": "object",
      "properties": {
        "commands": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "allow": {
      "type": "object",
      "properties": {
        "commands": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "gates": { "type": "object" },
    "secrets": {
      "type": "object",
      "properties": {
        "block_tools": { "type": "array", "items": { "type": "string" } },
        "rationale": { "type": "string" }
      }
    },
    "rationale": {
      "type": "object",
      "properties": {
        "text": { "type": "string" }
      }
    }
  }
}
