{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/policy.schema.json",
  "title": "Ontarch policy",
  "description": "Machine-readable policy: allowed and blocked behavior, gates, and agent rails. Canon: metadata-plane policy contract; agent-rails. Closed v0 shape covering agent-rails ([agent] allow/block, [gates], [secrets]) and command-tier ([allow]/[gate]/[block] commands/tools/paths/actions, [remote]).",
  "type": "object",
  "required": ["id", "applies_to", "version"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "applies_to": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^0\\.1(\\.[0-9]+)?$" },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env_flag": { "type": "string" },
        "allow": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "block": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "allow": {
      "description": "Command/tool allow table. v0: paths and actions must be empty or absent (unsupported); only commands/tools are enforced.",
      "allOf": [{ "$ref": "#/definitions/ruleTable" }]
    },
    "gate": {
      "description": "Command/tool gate table. v0: paths and actions must be empty or absent (unsupported); only commands/tools are enforced.",
      "allOf": [{ "$ref": "#/definitions/ruleTable" }]
    },
    "block": {
      "description": "Command/tool/path/action block table. paths and actions are supported for Deny.",
      "allOf": [{ "$ref": "#/definitions/ruleTable" }]
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "no_global_install": { "type": "boolean" },
        "no_secret_read": { "type": "boolean" },
        "no_shell_mutation": { "type": "boolean" }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "block_tools": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "rationale": { "type": "string" }
      }
    },
    "remote": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "writes": {
          "type": "string",
          "enum": ["blocked", "local-only", "elevated"]
        }
      }
    },
    "rationale": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" }
      }
    }
  },
  "definitions": {
    "ruleTable": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "paths": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["delete untracked files"]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
