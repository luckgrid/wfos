{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/runtime-command-record.schema.json",
  "title": "Takogami command execution record",
  "description": "Operational command execution records written under the resolved Takogami state home (default XDG state). Distinct from tracked Ontarch build-session provenance under logs.session_log_target / registry/sessions/, and from composed work-session manifests. Secret values, full inherited environment dumps, provider socket paths, and pane scrollback are forbidden.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "session_id",
    "started_at",
    "actor",
    "profile_id",
    "request",
    "policy_decision",
    "execution",
    "source_fingerprints",
    "output_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Mismatched schema_version is a typed contract error; never silently coerced."
    },
    "record_kind": {
      "type": "string",
      "const": "command_execution",
      "description": "Labels this record as a command execution audit record, not a composed work session."
    },
    "session_id": { "type": "string", "minLength": 1 },
    "parent_session_id": { "type": "string" },
    "work_session_id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional link to a composed work-session manifest. Opaque ID only."
    },
    "runtime_context": {
      "type": "object",
      "required": ["provider"],
      "additionalProperties": false,
      "description": "Optional provider-neutral terminal runtime link. Opaque IDs only — never socket paths or scrollback.",
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "description": "Terminal runtime provider (e.g. herdr, tmux, direct)."
        },
        "workspace_id": { "type": "string" },
        "tab_id": { "type": "string" },
        "pane_id": { "type": "string" }
      }
    },
    "started_at": { "type": "string", "minLength": 1 },
    "ended_at": { "type": "string" },
    "actor": { "type": "string", "const": "agent" },
    "profile_id": { "type": "string", "minLength": 1 },
    "request": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": true,
      "properties": {
        "command": { "type": "string" },
        "unit_id": { "type": "string" },
        "verb": { "type": "string" },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "resolution": {},
    "policy_decision": {},
    "execution": {
      "type": "object",
      "required": ["started", "outcome"],
      "additionalProperties": false,
      "properties": {
        "started": { "type": "boolean" },
        "pid": { "type": "integer", "minimum": 0 },
        "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
        "signal": { "type": "string" },
        "outcome": {
          "type": "string",
          "enum": [
            "completed",
            "denied",
            "gated",
            "failed_to_spawn",
            "interrupted",
            "controller_error",
            "abandoned",
            "pending"
          ]
        }
      }
    },
    "source_fingerprints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "algorithm", "digest"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "algorithm": { "type": "string", "const": "sha256" },
          "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "output_summary": {
      "type": "object",
      "required": ["stdout_bytes", "stderr_bytes", "truncated", "encoding", "compressor"],
      "additionalProperties": false,
      "properties": {
        "stdout_bytes": { "type": "integer", "minimum": 0 },
        "stderr_bytes": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" },
        "encoding": { "type": "string", "enum": ["utf-8", "lossy-utf-8", "binary"] },
        "compressor": {
          "type": "string",
          "enum": ["none", "rtk", "disabled", "unsupported", "unavailable", "failed"]
        }
      }
    },
    "validation": {},
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
