{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/unit.schema.json",
  "title": "Ontarch unit descriptor",
  "description": "Machine-readable descriptor for a WfOS unit (workspace, package, app, tool). Canon: lg_wfos_lvl_0_metadata_plane.md §10.1. A descriptor answers everything an agent needs to act on a unit, replacing a repo scan.",
  "type": "object",
  "required": ["id", "kind", "title", "status", "paths"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "kind": {
      "type": "string",
      "enum": [
        "workspace",
        "native-toolchain",
        "metadata-plane",
        "runtime-controller",
        "package-translator",
        "portable-component-runtime",
        "package",
        "app",
        "site",
        "pattern",
        "tool",
        "runtime",
        "agent",
        "policy"
      ]
    },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "planned", "draft", "prototype", "deprecated", "archived"]
    },
    "archetype": { "type": "string" },
    "brand": { "type": "string" },
    "version": { "type": "string" },
    "summary": { "type": "string" },
    "system_space": { "type": "string" },
    "domain": { "type": "string" },
    "system": { "type": "string" },
    "layer": {
      "type": "string",
      "enum": ["toolchain", "agent", "application", "configuration", "tool", "native-toolchain"]
    },
    "paths": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": { "type": "string" }
      }
    },
    "native": {
      "type": "object",
      "properties": {
        "manifests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "cli": {
      "type": "object",
      "properties": {
        "entry": { "type": "string" },
        "commands": { "type": "array", "items": { "type": "string" } }
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "provides": { "type": "array", "items": { "type": "string" } },
        "requires": { "type": "array", "items": { "type": "string" } }
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "allow_git_push": { "type": "boolean" },
        "allow_secret_read": { "type": "boolean" }
      }
    }
  }
}
