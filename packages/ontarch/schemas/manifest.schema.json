{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/manifest.schema.json",
  "title": "Ontarch run manifest",
  "description": "Provenance contract for a generated run. One small JSON read answers \"what is this, can I delete it\" without inspecting output files. Day-one writers: ontarch sync and ontarch scan (registry/manifest.json). Other bin/ writers are advised to emit the same shape. Canon: bin-archive provenance.",
  "type": "object",
  "required": ["id", "workflow", "source", "created_at", "tool", "outputs", "retention"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "source": { "type": "string" },
    "created_at": { "type": "string", "minLength": 1 },
    "tool": { "type": "string", "minLength": 1 },
    "tool_version": { "type": ["string", "null"] },
    "outputs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "environment": { "type": "object", "additionalProperties": true },
    "approved_to": { "type": ["string", "null"] },
    "retention": {
      "type": "string",
      "description": "review-before-delete | permanent | session-exports | auto-archive-after:<N>d (e.g. auto-archive-after:30d)",
      "pattern": "^(review-before-delete|permanent|session-exports|auto-archive-after:[0-9]+d)$"
    },
    "notes": { "type": "string" },
    "archive_reason": {
      "type": "string",
      "enum": ["superseded", "imported", "retired", "reference", "duplicate", "stale"],
      "description": "Why the run moved to archive (optional; set when archiving)."
    },
    "promoted_to": {
      "type": "string",
      "description": "Destination path when the run was promoted (optional)."
    }
  }
}
