{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/panoply.tools.schema.json",
  "title": "Panoply tools registry",
  "description": "Generated by `panoply doctor` from manifest/panoply.tools.toml.",
  "type": "object",
  "required": ["generated_at", "manifest_version", "summary", "tools"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "manifest_version": { "type": "string" },
    "host": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["total", "installed", "missing", "missing_default"],
      "properties": {
        "total": { "type": "integer" },
        "installed": { "type": "integer" },
        "missing": { "type": "integer" },
        "missing_default": { "type": "integer" }
      }
    },
    "missing_defaults": {
      "type": "array",
      "description": "ids of module-default tools not detected on this host",
      "items": { "type": "string" }
    },
    "roles": {
      "type": "array",
      "description": "replaceability matrix: the active member of each swappable role",
      "items": {
        "type": "object",
        "required": ["module", "default", "active", "active_kind"],
        "properties": {
          "module": { "type": "string" },
          "default": { "type": "string" },
          "active": { "type": "string" },
          "active_kind": { "type": "string", "enum": ["default", "alternative", "none"] }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "id", "installed", "default", "agent_safe", "detect"],
        "properties": {
          "module": { "type": "string" },
          "id": { "type": "string" },
          "installed": { "type": "boolean" },
          "default": { "type": "boolean" },
          "agent_safe": { "type": "boolean" },
          "detect": { "type": "string" },
          "brew": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    }
  }
}
