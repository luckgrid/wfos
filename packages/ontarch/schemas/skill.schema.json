{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/skill.schema.json",
  "title": "Ontarch skill record",
  "description": "A curated skill, template, or pattern record authored under Workstreams/.agents/skills/*.toml. The registry holds records only — bodies resolve on invocation from $SKILLS_HOME or repo templates. Indexed (flattened) into registry/skills.json by `ontarch sync`.",
  "type": "object",
  "required": ["id", "source", "kind"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "title": { "type": "string" },
    "source": {
      "type": "string",
      "enum": ["factory", "claude", "fabric", "wfos", "community"]
    },
    "kind": {
      "type": "string",
      "enum": ["skill", "template", "pattern", "command"]
    },
    "body_ref": { "type": "string" },
    "version": { "type": "string" },
    "supported_agent_apps": { "type": "array", "items": { "type": "string" } },
    "allowed_contexts": { "type": "array", "items": { "type": "string" } },
    "touches": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["network", "secrets", "fs-write", "fs-read", "none"]
      }
    },
    "risks": { "type": "array", "items": { "type": "string" } },
    "validator": { "type": "string" },
    "inputs": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "scan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "unscanned"]
        },
        "scanner": { "type": "string" },
        "hash": { "type": "string" },
        "scanned_at": { "type": "string" }
      }
    }
  }
}
