{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/schemas/scan.schema.json",
  "title": "Ontarch polyrepo scan report",
  "description": "A read-only, agent-safe report of workspace state across Build/src/workspaces. One report replaces N per-repo `git status` reads. Generated by `ontarch scan` into registry/scan.json (host-specific, gitignored); the human-readable projection is registry/SCAN.md. All fields come from read-only `git -C <dir>` and ontarch descriptors — no writes, no remote operations. Canon: persistence-sync / git hygiene.",
  "type": "object",
  "required": ["generated_at", "root", "summary", "workspaces"],
  "additionalProperties": true,
  "properties": {
    "generated_at": { "type": "string" },
    "root": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "total": { "type": "integer" },
        "clean": { "type": "integer" },
        "dirty": { "type": "integer" }
      }
    },
    "workspaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "git_root", "worktree_status"],
        "additionalProperties": true,
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "git_root": { "type": "string" },
          "remote_set": { "type": "array", "items": { "type": "string" } },
          "default_branch": { "type": ["string", "null"] },
          "active_branch": { "type": ["string", "null"] },
          "worktree_status": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "state": { "type": "string", "enum": ["clean", "dirty"] },
              "changed": { "type": "integer" },
              "worktrees": { "type": "integer" }
            }
          },
          "native_manifests": { "type": "array", "items": { "type": "string" } },
          "lint_check_commands": { "type": "array", "items": { "type": "string" } },
          "agent_scope_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "profile": { "type": "string" },
                "in_scope": { "type": "boolean" },
                "blocked": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
