{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/ontarch/graphs/edges.schema.json",
  "title": "Ontarch project graph",
  "description": "The generated relationship graph: nodes (units, capabilities, policies, actors) and directed edges between them. Canon: metadata-plane graphs. Generated by `ontarch sync` into registry/graph.json (host-specific, gitignored).",
  "type": "object",
  "required": ["nodes", "edges"],
  "additionalProperties": true,
  "properties": {
    "generated_at": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "workspace",
              "native-toolchain",
              "metadata-plane",
              "runtime-controller",
              "package-translator",
              "portable-component-runtime",
              "package",
              "app",
              "site",
              "pattern",
              "tool",
              "runtime",
              "agent",
              "policy",
              "capability",
              "actor",
              "profile",
              "skill"
            ]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "rel", "to"],
        "additionalProperties": true,
        "properties": {
          "from": { "type": "string" },
          "rel": {
            "type": "string",
            "enum": [
              "provides",
              "requires",
              "uses",
              "governed-by",
              "blocked-by",
              "packaged-by",
              "runs-on",
              "selects",
              "can-invoke"
            ]
          },
          "to": { "type": "string" }
        }
      }
    }
  }
}
