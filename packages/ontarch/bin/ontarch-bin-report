#!/usr/bin/env bash
# ontarch-bin-report — read-only inventory of Workstreams/*/bin/<workflow>/ directories.
# Writes registry/bin-inventory.json (machine) and registry/BIN-INVENTORY.md (human table).
# One report replaces N du/ls/stat explorations. Agent-safe: no writes under bin/.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/registry.sh
source "$_self/../lib/registry.sh"

ontarch_require_jq
mkdir -p "$ONTARCH_REGISTRY"

ontarch_info "ontarch bin-report — read-only inventory ($WS_ROOT/*/bin)"

ontarch_emit_bin_inventory > "$ONTARCH_REGISTRY/bin-inventory.json"

# BIN-INVENTORY.md: human projection, one row per workflow directory.
{
  printf '# Bin inventory report\n\n'
  # shellcheck disable=SC2016  # literal backticks for the generated markdown note
  printf 'GENERATED by `ontarch bin-report` (read-only). Regenerate: `moon run ontarch:bin-report`. Host-specific (gitignored).\n\n'
  printf 'generated_at: %s\n\n' "$(jq -r '.generated_at' "$ONTARCH_REGISTRY/bin-inventory.json")"
  printf 'summary: %s workflow dir(s) — %s with manifest\n\n' \
    "$(jq -r '.summary.total' "$ONTARCH_REGISTRY/bin-inventory.json")" \
    "$(jq -r '.summary.with_manifest' "$ONTARCH_REGISTRY/bin-inventory.json")"
  printf '| path | size | files | oldest_days | newest_days | manifest |\n'
  printf '|------|------|-------|-------------|-------------|----------|\n'
  jq -r '.workflows[] |
    (if .size_bytes >= 1073741824 then ((.size_bytes/1073741824)|floor|tostring) + "GiB"
     elif .size_bytes >= 1048576 then ((.size_bytes/1048576*10|floor)/10|tostring) + "MiB"
     elif .size_bytes >= 1024 then ((.size_bytes/1024*10|floor)/10|tostring) + "KiB"
     else (.size_bytes|tostring) + "B" end) as $sz |
    "| \(.path) | \($sz) | \(.file_count) | \(.oldest_file_age_days // "-") | \(.newest_file_age_days // "-") | \(if .manifest_present then "yes (\(.manifest_count))" else "no" end) |"' \
    "$ONTARCH_REGISTRY/bin-inventory.json"
} > "$ONTARCH_REGISTRY/BIN-INVENTORY.md"

n=$(jq -r '.summary.total' "$ONTARCH_REGISTRY/bin-inventory.json")
m=$(jq -r '.summary.with_manifest' "$ONTARCH_REGISTRY/bin-inventory.json")
ontarch_ok "bin-inventory.json ($n workflow dirs: $m with manifest)"
ontarch_ok "BIN-INVENTORY.md  -> registry/BIN-INVENTORY.md"
