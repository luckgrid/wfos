#!/usr/bin/env bash
# ontarch — metadata-plane build-time tasks (WfOS Level 0).
#
# Ontarch is data and contracts; it exposes no end-user runtime CLI. These tasks generate
# and validate the registry from descriptors, policies, and the Panoply tools registry. They
# are read-only over sources and write only generated registry output — agent-safe.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"

usage() {
  cat <<EOF
ontarch — metadata-plane tasks (build-time; no runtime CLI)

usage: ontarch <command>

commands:
  validate      validate descriptors and policies against their JSON schemas (gate)
  sync          generate the registry (units/skills/profiles/policies + graph) from sources
  scan          read-only polyrepo scan report (scan.json + SCAN.md) — report-only
  bin-report    read-only bin inventory (bin-inventory.json + BIN-INVENTORY.md)
  bin-cleanup   draft-safe cleanup planner (report-only|dry-run; archive/delete refuse)
  skills        on-demand skill registry tools (resolve, scan, map — report-only)
  secrets-scan  report-only secret scan (gitleaks) — detect | staged | dir <path>
  help          show this help

These are wired as moon tasks: \`moon run ontarch:validate\`, \`moon run ontarch:sync\`.
EOF
}

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    validate)     exec "$_self/ontarch-validate" "$@" ;;
    sync)         exec "$_self/ontarch-sync" "$@" ;;
    scan)         exec "$_self/ontarch-scan" "$@" ;;
    bin-report)   exec "$_self/ontarch-bin-report" "$@" ;;
    bin-cleanup)  exec "$_self/ontarch-bin-cleanup" "$@" ;;
    skills)       exec "$_self/ontarch-skills" "$@" ;;
    secrets-scan) exec "$_self/ontarch-gitleaks" "$@" ;;
    help|-h|--help) usage ;;
    *) ontarch_err "unknown command: $cmd"; echo; usage; exit 1 ;;
  esac
}

main "$@"
