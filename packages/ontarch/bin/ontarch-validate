#!/usr/bin/env bash
# ontarch validate — GATE. Validate descriptors, policies, and the generated graph
# against their JSON schemas. Read-only and agent-safe. The schema is the source of truth:
# required keys and enums are read from the schema, not hardcoded here.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/descriptor.sh
source "$_self/../lib/descriptor.sh"
# shellcheck source=../lib/registry.sh
source "$_self/../lib/registry.sh"

ontarch_require_jq

fail=0

# Check a present field's value against its schema enum (no-op if field absent).
_check_enum() {
  local full="$1" field="$2" schema="$3" label="$4" val
  val="$(jq -r --arg k "$field" '.[$k] // empty' <<<"$full")"
  [ -n "$val" ] || return 0
  if jq -e --arg k "$field" 'has("properties") and (.properties[$k].enum != null)' "$schema" >/dev/null; then
    if ! jq -e --arg k "$field" --arg v "$val" '.properties[$k].enum | index($v)' "$schema" >/dev/null; then
      ontarch_err "$label: $field='$val' is not in the schema enum"
      return 1
    fi
  fi
  return 0
}

# Keep runtime routing validation aligned with the closed structured-entrypoint schema.
_routing_entrypoints_ok() {
  jq -e '
    (.entrypoints // {}) as $entrypoints
    | ($entrypoints | type == "object")
    and all($entrypoints[];
      (type == "string")
      or (
        type == "object"
        and ((keys - [
          "program", "args", "cwd", "env_keys", "backend", "adapter",
          "source_manifests", "required_policies", "execution_class", "runtime_provider"
        ]) | length == 0)
        and (.program | type == "string" and length > 0)
        and ((.args // []) | type == "array" and all(.[]; type == "string"))
        and ((.env_keys // []) | type == "array" and all(.[]; type == "string"))
        and ((.source_manifests // []) | type == "array" and all(.[]; type == "string"))
        and ((.required_policies // []) | type == "array" and all(.[]; type == "string"))
        and ((.execution_class // "direct") as $class
          | if $class == "direct" then
              .runtime_provider == null
            elif $class == "interactive_session" then
              (.runtime_provider | type == "string" and length > 0)
            else
              false
            end)
      )
    )
  ' <<<"$1" >/dev/null 2>&1
}

_validate_descriptors() {
  local schema="$ONTARCH_SCHEMAS/unit.schema.json"
  [ -f "$schema" ] || ontarch_die "missing schema: $schema"
  local required count=0
  required="$(jq -r '.required[]' "$schema")"

  ontarch_info "descriptors (vs schemas/unit.schema.json)"
  local f src full id req
  while IFS=$'\037' read -r f src; do
    [ -n "$f" ] || continue
    count=$((count + 1))
    full="$(ontarch_descriptor_json "$f")"
    id="$(jq -r '.id // "?"' <<<"$full")"
    local label="$id [$src]"
    local unit_fail=0

    for req in $required; do
      jq -e --arg k "$req" 'has($k)' <<<"$full" >/dev/null \
        || { ontarch_err "$label: missing required '$req'"; unit_fail=1; }
    done
    jq -e '.paths.root // empty | length > 0' <<<"$full" >/dev/null \
      || { ontarch_err "$label: paths.root is required and must be non-empty"; unit_fail=1; }

    _check_enum "$full" kind "$schema" "$label" || unit_fail=1
    _check_enum "$full" status "$schema" "$label" || unit_fail=1
    _check_enum "$full" layer "$schema" "$label" || unit_fail=1
    _routing_entrypoints_ok "$full" \
      || { ontarch_err "$label: structured entrypoint violates routing schema"; unit_fail=1; }

    if [ "$unit_fail" -eq 0 ]; then
      printf '  %sok%s  %-12s %s%s%s\n' "$_C_GREEN" "$_C_RESET" "$id" "$_C_DIM" "$f" "$_C_RESET"
    else
      fail=1
    fi
  done < <(ontarch_find_descriptors)

  [ "$count" -gt 0 ] || { ontarch_err "no descriptors found"; fail=1; }
  ontarch_info "validated $count descriptor(s)"
}

# Closed v0 policy shape checker (mirrors policy.schema.json additionalProperties:false).
# Args: <policy-json>
_policy_shape_ok() {
  jq -e '
    def known_root: ["id","applies_to","version","agent","allow","gate","block","gates","secrets","remote","rationale"];
    def known_agent: ["env_flag","allow","block"];
    def known_rule: ["commands","tools","paths","actions"];
    def known_gates: ["no_global_install","no_secret_read","no_shell_mutation"];
    def known_secrets: ["block_tools","rationale"];
    def known_remote: ["writes"];
    def known_rationale: ["text"];
    def known_actions: ["delete untracked files"];
    def obj_keys_ok($known): (type != "object") or ((keys - $known) | length == 0);
    def unique_ok($arr): ($arr | length) == ($arr | unique | length);
    def str_array_ok($arr):
      ($arr | map(type == "string") | all) and unique_ok($arr);
    def rule_ok($allow_gate):
      type == "object"
      and obj_keys_ok(known_rule)
      and str_array_ok(.commands // [])
      and str_array_ok(.tools // [])
      and str_array_ok(.paths // [])
      and ((.actions // []) | map(. as $a | known_actions | index($a)) | all)
      and unique_ok(.actions // [])
      and (
        ($allow_gate | not)
        or (
          ((.paths // []) | length == 0)
          and ((.actions // []) | length == 0)
        )
      );
    (has("id") and has("applies_to") and has("version"))
    and (.id | type == "string" and test("^[a-z0-9][a-z0-9._-]*$"))
    and (.applies_to | type == "string" and length > 0)
    and (.version | type == "string" and test("^0\\.1(\\.[0-9]+)?$"))
    and obj_keys_ok(known_root)
    and ((has("agent") | not) or (
      .agent | type == "object" and obj_keys_ok(known_agent)
      and ((has("env_flag") | not) or (.env_flag | type == "string"))
      and str_array_ok(.allow // [])
      and str_array_ok(.block // [])
    ))
    and ((has("allow") | not) or (.allow | rule_ok(true)))
    and ((has("gate") | not) or (.gate | rule_ok(true)))
    and ((has("block") | not) or (.block | rule_ok(false)))
    and ((has("gates") | not) or (
      .gates | type == "object" and obj_keys_ok(known_gates)
      and ((has("no_global_install") | not) or (.no_global_install | type == "boolean"))
      and ((has("no_secret_read") | not) or (.no_secret_read | type == "boolean"))
      and ((has("no_shell_mutation") | not) or (.no_shell_mutation | type == "boolean"))
    ))
    and ((has("secrets") | not) or (
      .secrets | type == "object" and obj_keys_ok(known_secrets)
      and str_array_ok(.block_tools // [])
      and ((has("rationale") | not) or (.rationale | type == "string"))
    ))
    and ((has("remote") | not) or (
      .remote | type == "object" and obj_keys_ok(known_remote)
      and ((has("writes") | not) or (.writes | . == "blocked" or . == "local-only" or . == "elevated"))
    ))
    and ((has("rationale") | not) or (
      .rationale | type == "object" and obj_keys_ok(known_rationale)
      and ((has("text") | not) or (.text | type == "string"))
    ))
  ' <<<"$1" >/dev/null
}

_validate_policies() {
  local schema="$ONTARCH_SCHEMAS/policy.schema.json"
  [ -f "$schema" ] || ontarch_die "missing schema: $schema"
  local required count=0
  required="$(jq -r '.required[]' "$schema")"

  ontarch_info "policies (vs schemas/policy.schema.json)"
  local f full id req pol_fail
  for f in "$ONTARCH_POLICIES"/*.toml; do
    [ -e "$f" ] || continue
    count=$((count + 1))
    full="$(ontarch_descriptor_json "$f")"
    id="$(jq -r '.id // "?"' <<<"$full")"
    pol_fail=0

    for req in $required; do
      jq -e --arg k "$req" 'has($k)' <<<"$full" >/dev/null \
        || { ontarch_err "policy $id: missing required '$req'"; pol_fail=1; }
    done

    # id must match the schema pattern (^[a-z0-9][a-z0-9._-]*$)
    if ! jq -e '.id | test("^[a-z0-9][a-z0-9._-]*$")' <<<"$full" >/dev/null 2>&1; then
      ontarch_err "policy $id: id does not match schema pattern"
      pol_fail=1
    fi

    if ! _policy_shape_ok "$full"; then
      ontarch_err "policy $id: closed v0 enforcement shape failed"
      pol_fail=1
    fi

    if [ "$pol_fail" -eq 0 ]; then
      printf '  %sok%s  %-20s %s%s%s\n' "$_C_GREEN" "$_C_RESET" "$id" "$_C_DIM" "$f" "$_C_RESET"
    else
      fail=1
    fi
  done

  [ "$count" -gt 0 ] || { ontarch_warn "no policies found"; }
  [ "$count" -gt 0 ] && ontarch_info "validated $count policy/policies"
}

# Positive/negative fixtures for closed policy enforcement shape.
_selfcheck_policy_enforcement_shape() {
  ontarch_info "policy enforcement shape (selfcheck)"
  local good bad
  good='{"id":"takogami.agent","applies_to":"agent","version":"0.1.0","allow":{"commands":["takogami build"]},"gate":{"commands":["takogami bin cleanup --mode dry-run"]},"block":{"commands":["takogami bin cleanup --mode archive"],"actions":["delete untracked files"]},"remote":{"writes":"elevated"},"gates":{"no_secret_read":true}}'
  if ! _policy_shape_ok "$good"; then
    ontarch_err "policy shape selfcheck: positive fixture should pass"
    fail=1
  fi

  # misspelled rule-table field
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","allow":{"command":["x"]}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: misspelled commands field should fail"
    fail=1
  fi
  # non-boolean capability gate
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","gates":{"no_secret_read":"yes"}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: non-boolean gate should fail"
    fail=1
  fi
  # unsupported action
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","block":{"actions":["format disk"]}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: unsupported action should fail"
    fail=1
  fi
  # bad remote enum
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","remote":{"writes":"always"}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: bad remote enum should fail"
    fail=1
  fi
  # unknown top-level enforcement table
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","deny":{"commands":["x"]}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: unknown enforcement table should fail"
    fail=1
  fi
  # unsupported version
  bad='{"id":"bad","applies_to":"agent","version":"0.2.0"}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: unsupported version should fail"
    fail=1
  fi
  # duplicate array items
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","allow":{"commands":["x","x"]}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: duplicate commands should fail"
    fail=1
  fi
  # authored source field (generated-only; reject on authored)
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","source":"policies/bad.policy.toml"}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: authored source should fail"
    fail=1
  fi
  # non-empty allow.paths (unsupported in v0)
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","allow":{"paths":["Build/**"]}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: allow.paths non-empty should fail"
    fail=1
  fi
  # non-string nested scalar (commands member)
  bad='{"id":"bad","applies_to":"agent","version":"0.1.0","allow":{"commands":[1]}}'
  if _policy_shape_ok "$bad"; then
    ontarch_err "policy shape selfcheck: non-string command should fail"
    fail=1
  fi
}

# SkillSpector gate pairing: loads_external=true requires skillspector_scan in required_validators.
# Args: <profile-json>
_profile_skillspector_gate_ok() {
  jq -e '
    (.skills.loads_external // false) != true
    or ((.validators.required_validators // []) | index("skillspector_scan"))
  ' <<<"$1" >/dev/null
}

_selfcheck_skillspector_gate() {
  ontarch_info "skillspector gate (selfcheck)"
  local bad='{"id":"_gate_negative","skills":{"loads_external":true},"validators":{"required_validators":["frontmatter"]}}'
  local good='{"id":"_gate_positive","skills":{"loads_external":true},"validators":{"required_validators":["skillspector_scan"]}}'
  if _profile_skillspector_gate_ok "$bad"; then
    ontarch_err "skillspector selfcheck: negative fixture should fail the gate"
    fail=1
  else
    printf '  %sok%s  negative fixture rejected\n' "$_C_GREEN" "$_C_RESET"
  fi
  if _profile_skillspector_gate_ok "$good"; then
    printf '  %sok%s  positive fixture accepted\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "skillspector selfcheck: positive fixture should pass the gate"
    fail=1
  fi
}

# Collect skill ids from .agents/skills/*.toml (one id per line).
_ontarch_skill_ids_from_sources() {
  local f id
  for f in "$AGENTS_HOME"/skills/*.toml; do
    [ -e "$f" ] || continue
    id="$(jq -r '.id // empty' <<<"$(ontarch_descriptor_json "$f")")"
    [ -n "$id" ] && printf '%s\n' "$id"
  done
}

# Args: <skill-id> <profile-id> — loadable skills must have passed, non-stale scan.
_skill_loadable_scan_ok() {
  local sid="$1" profile="$2" f full
  for f in "$AGENTS_HOME"/skills/*.toml; do
    [ -e "$f" ] || continue
    full="$(ontarch_descriptor_json "$f")"
    [ "$(jq -r '.id' <<<"$full")" = "$sid" ] || continue
    if jq -e '
      (.scan.status // "unscanned") == "passed"
      and (.scan.hash // "") != ""
      and (.scan.hash == (.version // ""))
    ' <<<"$full" >/dev/null; then
      return 0
    fi
    ontarch_err "profile $profile: loadable skill '$sid' has no passing scan or stale scan.hash != version — re-scan required"
    return 1
  done
  ontarch_err "profile $profile: loadable skill '$sid' not found in registry"
  return 1
}

_selfcheck_skill_scan_gate() {
  ontarch_info "skill scan gate (selfcheck)"
  local bad='{"id":"_scan_bad","version":"abc","scan":{"status":"unscanned","hash":""}}'
  local good='{"id":"_scan_good","version":"abc","scan":{"status":"passed","hash":"abc"}}'
  if jq -e '
    (.scan.status // "unscanned") == "passed"
    and (.scan.hash // "") != ""
    and (.scan.hash == (.version // ""))
  ' <<<"$bad" >/dev/null; then
    ontarch_err "skill scan selfcheck: negative fixture should fail"
    fail=1
  else
    printf '  %sok%s  negative scan fixture rejected\n' "$_C_GREEN" "$_C_RESET"
  fi
  if jq -e '
    (.scan.status // "unscanned") == "passed"
    and (.scan.hash // "") != ""
    and (.scan.hash == (.version // ""))
  ' <<<"$good" >/dev/null; then
    printf '  %sok%s  positive scan fixture accepted\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "skill scan selfcheck: positive fixture should pass"
    fail=1
  fi
}

# ponytail: frontmatter check is a single --- delimiter pair at file start.
_skill_frontmatter_ok() {
  local f="$1"
  [ -f "$f" ] || return 1
  awk 'BEGIN { found=0; ok=0 }
       NR==1 && /^---$/ { found=1; next }
       found && /^---$/ { ok=1; exit }
       END { exit ok ? 0 : 1 }' "$f"
}

_validate_skills() {
  local schema="$ONTARCH_SCHEMAS/skill.schema.json"
  [ -f "$schema" ] || ontarch_die "missing schema: $schema"
  local dir="$AGENTS_HOME/skills"
  [ -d "$dir" ] || { ontarch_warn "no .agents/skills directory"; return 0; }
  local required count=0
  required="$(jq -r '.required[]' "$schema")"
  local kind_enum source_enum
  kind_enum="$(jq -r '.properties.kind.enum[]' "$schema")"
  source_enum="$(jq -r '.properties.source.enum[]' "$schema")"

  ontarch_info "skills (vs schemas/skill.schema.json)"
  local f full id req sk_fail kind source touches risks body_ref body_path
  for f in "$dir"/*.toml; do
    [ -e "$f" ] || continue
    count=$((count + 1))
    full="$(ontarch_descriptor_json "$f")"
    id="$(jq -r '.id // "?"' <<<"$full")"
    sk_fail=0

    for req in $required; do
      jq -e --arg k "$req" 'has($k)' <<<"$full" >/dev/null \
        || { ontarch_err "skill $id: missing required '$req'"; sk_fail=1; }
    done

    if ! jq -e '.id | test("^[a-z0-9][a-z0-9._-]*$")' <<<"$full" >/dev/null 2>&1; then
      ontarch_err "skill $id: id does not match schema pattern"
      sk_fail=1
    fi

    kind="$(jq -r '.kind // empty' <<<"$full")"
    source="$(jq -r '.source // empty' <<<"$full")"
    echo "$kind_enum" | grep -qx "$kind" \
      || { ontarch_err "skill $id: kind='$kind' is not in the schema enum"; sk_fail=1; }
    echo "$source_enum" | grep -qx "$source" \
      || { ontarch_err "skill $id: source='$source' is not in the schema enum"; sk_fail=1; }

    touches="$(jq -r '(.touches // []) | length' <<<"$full")"
    risks="$(jq -r '(.risks // []) | length' <<<"$full")"
    if [ "$touches" -gt 0 ] && [ "$risks" -eq 0 ]; then
      ontarch_err "skill $id: touches is non-empty but risks is empty"
      sk_fail=1
    fi

    kind="$(jq -r '.kind // "skill"' <<<"$full")"
    body_ref="$(jq -r '.body_ref // .id' <<<"$full")"
    if [ "$kind" = "template" ]; then
      jq -e '.validator // empty | length > 0' <<<"$full" >/dev/null \
        || { ontarch_err "skill $id: kind=template requires a non-empty validator"; sk_fail=1; }
      body_path="$AGENTS_HOME/skills/$body_ref"
      [ -f "$body_path" ] \
        || { ontarch_err "skill $id: template body missing at $body_path"; sk_fail=1; }
      _skill_frontmatter_ok "$body_path" \
        || { ontarch_err "skill $id: template body missing valid frontmatter"; sk_fail=1; }
    fi

    if [ "$kind" = "pattern" ]; then
      scan_status="$(jq -r '.scan.status // "unscanned"' <<<"$full")"
      [ "$scan_status" = "unscanned" ] \
        && ontarch_warn "skill $id: pattern catalogued but unscanned (not loadable until scanned)"
    fi

    if [ "$sk_fail" -eq 0 ]; then
      printf '  %sok%s  %-24s %s%s%s\n' "$_C_GREEN" "$_C_RESET" "$id" "$_C_DIM" "$f" "$_C_RESET"
    else
      fail=1
    fi
  done

  [ "$count" -gt 0 ] || { ontarch_warn "no skill records found"; }
  [ "$count" -gt 0 ] && ontarch_info "validated $count skill record(s)"
}

_validate_profiles() {
  local schema="$ONTARCH_SCHEMAS/profile.schema.json"
  [ -f "$schema" ] || ontarch_die "missing schema: $schema"
  local dir="$AGENTS_HOME/profiles"
  [ -d "$dir" ] || { ontarch_warn "no .agents/profiles directory"; return 0; }
  local required count=0
  required="$(jq -r '.required[]' "$schema")"
  local rwp_enum iso_enum
  rwp_enum="$(jq -r '.properties.policy.properties.remote_write_policy.enum[]' "$schema")"
  iso_enum="$(jq -r '.properties.isolation.properties.mode.enum[]' "$schema")"

  ontarch_info "profiles (vs schemas/profile.schema.json)"
  local f full id req pr_fail rwp sa
  for f in "$dir"/*.toml; do
    [ -e "$f" ] || continue
    count=$((count + 1))
    full="$(ontarch_descriptor_json "$f")"
    id="$(jq -r '.id // "?"' <<<"$full")"
    pr_fail=0

    for req in $required; do
      jq -e --arg k "$req" 'has($k)' <<<"$full" >/dev/null \
        || { ontarch_err "profile $id: missing required '$req'"; pr_fail=1; }
    done

    # id must match the schema pattern (^[a-z0-9][a-z0-9._-]*$)
    if ! jq -e '.id | test("^[a-z0-9][a-z0-9._-]*$")' <<<"$full" >/dev/null 2>&1; then
      ontarch_err "profile $id: id does not match schema pattern"
      pr_fail=1
    fi

    # scope.allowed_paths must be a non-empty array
    jq -e '(.scope.allowed_paths // []) | type == "array" and length > 0' <<<"$full" >/dev/null \
      || { ontarch_err "profile $id: scope.allowed_paths is required and must be a non-empty array"; pr_fail=1; }

    # policy.remote_write_policy, when present, must be in the schema enum
    rwp="$(jq -r '.policy.remote_write_policy // empty' <<<"$full")"
    if [ -n "$rwp" ] && ! echo "$rwp_enum" | grep -qx "$rwp"; then
      ontarch_err "profile $id: policy.remote_write_policy='$rwp' is not in the schema enum"
      pr_fail=1
    fi

    # isolation.mode, when present, must be in the schema enum (worktree|branch|main)
    local iso
    iso="$(jq -r '.isolation.mode // empty' <<<"$full")"
    if [ -n "$iso" ] && ! echo "$iso_enum" | grep -qx "$iso"; then
      ontarch_err "profile $id: isolation.mode='$iso' is not in the schema enum"
      pr_fail=1
    fi

    # policy.secret_access, when present, must be boolean
    sa="$(jq -r '.policy | has("secret_access")' <<<"$full" 2>/dev/null)"
    if [ "$sa" = "true" ]; then
      jq -e '.policy.secret_access | type == "boolean"' <<<"$full" >/dev/null \
        || { ontarch_err "profile $id: policy.secret_access must be boolean"; pr_fail=1; }
    fi

    # SkillSpector gate: any profile that loads external skills MUST require a
    # skillspector_scan. An unscanned skill is an unreviewed dependency and does not load.
    if ! _profile_skillspector_gate_ok "$full"; then
      ontarch_err "profile $id: loads_external skills but required_validators is missing 'skillspector_scan' (SkillSpector gate)"
      pr_fail=1
    fi

    # Cross-ref allowed_skill_ids against the curated skill registry.
    local sid skill_ids
    skill_ids="$(_ontarch_skill_ids_from_sources)"
    for sid in $(jq -r '.skills.allowed_skill_ids // [] | .[]' <<<"$full" 2>/dev/null); do
      echo "$skill_ids" | grep -qx "$sid" \
        || { ontarch_err "profile $id: allowed_skill_ids references unknown skill '$sid'"; pr_fail=1; }
    done

    # Loadable-skill scan gate: listed skills need a passing, non-stale scan.
    for sid in $(jq -r '.skills.allowed_skill_ids // [] | .[]' <<<"$full" 2>/dev/null); do
      _skill_loadable_scan_ok "$sid" "$id" || pr_fail=1
    done

    if [ "$pr_fail" -eq 0 ]; then
      printf '  %sok%s  %-24s %s%s%s\n' "$_C_GREEN" "$_C_RESET" "$id" "$_C_DIM" "$f" "$_C_RESET"
    else
      fail=1
    fi
  done

  [ "$count" -gt 0 ] || { ontarch_warn "no profiles found"; }
  [ "$count" -gt 0 ] && ontarch_info "validated $count profile(s)"
}

_validate_scan() {
  local schema="$ONTARCH_SCHEMAS/scan.schema.json"
  local scan="$ONTARCH_REGISTRY/scan.json"
  [ -f "$schema" ] || ontarch_die "missing schema: $schema"
  [ -f "$scan" ]   || { ontarch_warn "scan.json absent — run 'moon run ontarch:scan' first"; return 0; }

  ontarch_info "scan report (vs schemas/scan.schema.json)"
  local sfail=0 req
  for req in $(jq -r '.required[]' "$schema"); do
    jq -e --arg k "$req" 'has($k)' "$scan" >/dev/null \
      || { ontarch_err "scan: missing required '$req'"; sfail=1; }
  done

  # each workspace entry must carry the required workspace keys
  local wreq
  wreq="$(jq -r '.properties.workspaces.items.required[]' "$schema")"
  local missing
  for req in $wreq; do
    missing="$(jq -r --arg k "$req" '[.workspaces[] | select(has($k) | not) | .path] | length' "$scan")"
    [ "$missing" = "0" ] || { ontarch_err "scan: $missing workspace(s) missing '$req'"; sfail=1; }
  done

  # worktree_status.state must be clean|dirty
  local badstate
  badstate="$(jq -r '[.workspaces[] | select((.worktree_status.state // "") | test("^(clean|dirty)$") | not)] | length' "$scan")"
  [ "$badstate" = "0" ] || { ontarch_err "scan: $badstate workspace(s) with invalid worktree_status.state"; sfail=1; }

  if [ "$sfail" -eq 0 ]; then
    printf '  %sok%s  scan.json (%s workspaces) — report valid\n' \
      "$_C_GREEN" "$_C_RESET" "$(jq -r '.summary.total' "$scan")"
  else
    fail=1
  fi
}

# Soft structural check for the bin inventory (no dedicated schema — fields are
# defined by ontarch_emit_bin_inventory). Warns if absent; validates shape when present.
_validate_bin_inventory() {
  local inv="$ONTARCH_REGISTRY/bin-inventory.json"
  [ -f "$inv" ] || { ontarch_warn "bin-inventory.json absent — run 'moon run ontarch:bin-report' first"; return 0; }

  ontarch_info "bin inventory (structural)"
  local ifail=0 req
  for req in generated_at root summary workflows; do
    jq -e --arg k "$req" 'has($k)' "$inv" >/dev/null \
      || { ontarch_err "bin-inventory: missing required '$req'"; ifail=1; }
  done

  local missing
  for req in path size_bytes file_count manifest_present manifest_count; do
    missing="$(jq -r --arg k "$req" '[.workflows[] | select(has($k) | not) | .path] | length' "$inv")"
    [ "$missing" = "0" ] || { ontarch_err "bin-inventory: $missing workflow(s) missing '$req'"; ifail=1; }
  done

  # oldest >= newest when both present (ages are days-since-mtime)
  local badage
  badage="$(jq -r '[.workflows[]
    | select(.oldest_file_age_days != null and .newest_file_age_days != null)
    | select(.oldest_file_age_days < .newest_file_age_days)] | length' "$inv")"
  [ "$badage" = "0" ] || { ontarch_err "bin-inventory: $badage workflow(s) with oldest < newest age"; ifail=1; }

  if [ "$ifail" -eq 0 ]; then
    printf '  %sok%s  bin-inventory.json (%s workflows) — report valid\n' \
      "$_C_GREEN" "$_C_RESET" "$(jq -r '.summary.total' "$inv")"
  else
    fail=1
  fi
}

# Retention pattern from manifest.schema.json (concrete auto-archive-after:<N>d allowed).
_manifest_retention_ok() {
  jq -e '.retention | test("^(review-before-delete|permanent|session-exports|auto-archive-after:[0-9]+d)$")' <<<"$1" >/dev/null
}

_manifest_archive_reason_ok() {
  local reason
  reason="$(jq -r '.archive_reason // empty' <<<"$1")"
  [ -z "$reason" ] && return 0
  case "$reason" in
    superseded|imported|retired|reference|duplicate|stale) return 0 ;;
    *) return 1 ;;
  esac
}

# Validate one manifest JSON document against required keys + retention/archive enums.
# Args: <label> <json>
_check_manifest_doc() {
  local label="$1" full="$2" schema="$ONTARCH_SCHEMAS/manifest.schema.json"
  local mfail=0 req
  for req in $(jq -r '.required[]' "$schema"); do
    jq -e --arg k "$req" 'has($k)' <<<"$full" >/dev/null \
      || { ontarch_err "$label: missing required '$req'"; mfail=1; }
  done
  jq -e '(.outputs // []) | type == "array" and length > 0' <<<"$full" >/dev/null \
    || { ontarch_err "$label: outputs must be a non-empty array"; mfail=1; }
  _manifest_retention_ok "$full" \
    || { ontarch_err "$label: retention='$(jq -r '.retention // empty' <<<"$full")' is not a valid retention value"; mfail=1; }
  _manifest_archive_reason_ok "$full" \
    || { ontarch_err "$label: archive_reason='$(jq -r '.archive_reason // empty' <<<"$full")' is not in the schema enum"; mfail=1; }
  return "$mfail"
}

_selfcheck_manifest_retention() {
  ontarch_info "manifest retention (selfcheck)"
  local good_fixed='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"],"retention":"review-before-delete"}'
  local good_auto='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"],"retention":"auto-archive-after:30d"}'
  local bad_ret='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"],"retention":"auto-archive-after:NNd"}'
  local bad_missing='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"]}'
  if _manifest_retention_ok "$good_fixed" && _manifest_retention_ok "$good_auto"; then
    printf '  %sok%s  retention fixed + auto-archive-after:30d accepted\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "manifest retention selfcheck: valid retentions should pass"
    fail=1
  fi
  if _manifest_retention_ok "$bad_ret"; then
    ontarch_err "manifest retention selfcheck: literal NNd should fail"
    fail=1
  else
    printf '  %sok%s  literal auto-archive-after:NNd rejected\n' "$_C_GREEN" "$_C_RESET"
  fi
  if _check_manifest_doc "_missing" "$bad_missing" 2>/dev/null; then
    ontarch_err "manifest retention selfcheck: missing retention should fail"
    fail=1
  else
    printf '  %sok%s  missing retention rejected\n' "$_C_GREEN" "$_C_RESET"
  fi
}

_selfcheck_manifest_archive_reason() {
  ontarch_info "manifest archive_reason (selfcheck)"
  local good='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"],"retention":"review-before-delete","archive_reason":"stale","promoted_to":"Plan/bin/archives/x/"}'
  local bad='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"],"retention":"review-before-delete","archive_reason":"yeeted"}'
  local none='{"id":"g","workflow":"w","source":"s","created_at":"t","tool":"ontarch","outputs":["o"],"retention":"review-before-delete"}'
  if _check_manifest_doc "_archive_good" "$good" && _manifest_archive_reason_ok "$none"; then
    printf '  %sok%s  archive_reason=stale + promoted_to + absent reason accepted\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "manifest archive_reason selfcheck: valid archive fields should pass"
    fail=1
  fi
  if _check_manifest_doc "_archive_bad" "$bad" 2>/dev/null; then
    ontarch_err "manifest archive_reason selfcheck: invalid reason should fail"
    fail=1
  else
    printf '  %sok%s  invalid archive_reason rejected\n' "$_C_GREEN" "$_C_RESET"
  fi
}

# Routing projection must retain every field needed to construct a ResolvedCommand.
# Fixture fails if ontarch_unit_record drops structured entrypoints or CLI metadata.
_selfcheck_routing_projection() {
  ontarch_info "routing projection (selfcheck)"
  local full rec
  full='{"id":"proj-fixture","kind":"runtime-controller","title":"Proj","status":"active","paths":{"root":"x"},"native":{"manifests":["Cargo.toml"]},"cli":{"entry":"takogami","commands":["build","doctor"]},"entrypoints":{"build":{"program":"moon","args":["run","takogami:build"],"cwd":".","env_keys":["PATH"],"backend":"moon","adapter":"moon-task","source_manifests":["Cargo.toml"],"required_policies":["panoply.agent"],"execution_class":"direct","runtime_provider":null},"legacy":"moon run x"},"capabilities":{"provides":["a"],"requires":["b"]},"policy":{"allow_git_push":false}}'
  rec="$(ontarch_unit_record "$full" "central")"
  if ! jq -e '
    .cli.entry == "takogami"
    and (.cli.commands | index("build"))
    and .entrypoints.build.program == "moon"
    and (.entrypoints.build.args | index("takogami:build"))
    and .entrypoints.build.cwd == "."
    and (.entrypoints.build.env_keys | index("PATH"))
    and .entrypoints.build.backend == "moon"
    and .entrypoints.build.adapter == "moon-task"
    and (.entrypoints.build.source_manifests | index("Cargo.toml"))
    and (.entrypoints.build.required_policies | index("panoply.agent"))
    and .entrypoints.build.execution_class == "direct"
    and (
      (.entrypoints.build | has("runtime_provider") | not)
      or .entrypoints.build.runtime_provider == null
    )
    and .entrypoints.legacy == "moon run x"
    and (.native_manifests | index("Cargo.toml"))
  ' <<<"$rec" >/dev/null; then
    ontarch_err "routing projection selfcheck: dropped ResolvedCommand input fields"
    fail=1
  else
    printf '  %sok%s  structured entrypoints + cli metadata retained\n' "$_C_GREEN" "$_C_RESET"
  fi
}

_selfcheck_routing_schema() {
  ontarch_info "routing schema parity (selfcheck)"
  local valid_direct valid_interactive unknown omitted_provider direct_provider interactive_empty invalid_failed=0
  valid_direct='{"entrypoints":{"build":{"program":"moon","args":["run","x"]}}}'
  valid_interactive='{"entrypoints":{"dev":{"program":"demo","execution_class":"interactive_session","runtime_provider":"herdr"}}}'
  unknown='{"entrypoints":{"build":{"program":"moon","arg":["run","x"]}}}'
  omitted_provider='{"entrypoints":{"build":{"program":"moon","runtime_provider":"herdr"}}}'
  direct_provider='{"entrypoints":{"build":{"program":"moon","execution_class":"direct","runtime_provider":"herdr"}}}'
  interactive_empty='{"entrypoints":{"dev":{"program":"demo","execution_class":"interactive_session","runtime_provider":""}}}'

  if _routing_entrypoints_ok "$valid_direct" && _routing_entrypoints_ok "$valid_interactive"; then
    printf '  %sok%s  valid direct + interactive routing accepted\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "routing schema selfcheck: valid fixtures should pass"
    fail=1
  fi
  for fixture in "$unknown" "$omitted_provider" "$direct_provider" "$interactive_empty"; do
    if _routing_entrypoints_ok "$fixture"; then
      ontarch_err "routing schema selfcheck: invalid fixture should fail"
      fail=1
      invalid_failed=1
    fi
  done
  if [ "$invalid_failed" -eq 0 ]; then
    printf '  %sok%s  unknown/provider-invalid routing rejected\n' "$_C_GREEN" "$_C_RESET"
  fi
}

# Registry generation fingerprints must be present on units.json after sync.
_selfcheck_registry_generation() {
  ontarch_info "registry generation (selfcheck)"
  local tmp gen units
  tmp="$(mktemp)"
  printf 'fixture-bytes\n' >"$tmp"
  gen="$(ontarch_registry_generation "$tmp")"
  rm -f "$tmp"
  if ! jq -e '
    (.generated_at | type == "string")
    and (.source_fingerprints | type == "array")
    and (.source_fingerprints | length) >= 1
    and .source_fingerprints[0].algorithm == "sha256"
    and (.source_fingerprints[0].digest | length) == 64
  ' <<<"$gen" >/dev/null; then
    ontarch_err "registry generation selfcheck: ontarch_registry_generation shape invalid"
    fail=1
  else
    printf '  %sok%s  ontarch_registry_generation helper shape\n' "$_C_GREEN" "$_C_RESET"
  fi
  units="$ONTARCH_REGISTRY/units.json"
  if [ -f "$units" ]; then
    if ! jq -e '
      (.registry_generation.generated_at | type == "string")
      and (.registry_generation.source_fingerprints | type == "array")
    ' "$units" >/dev/null; then
      ontarch_err "units.json missing registry_generation — run ontarch sync"
      fail=1
    else
      printf '  %sok%s  units.json registry_generation present\n' "$_C_GREEN" "$_C_RESET"
    fi
  fi
}

_validate_runtime_schemas() {
  local out_schema="$ONTARCH_SCHEMAS/command-output.schema.json"
  local sess_schema="$ONTARCH_SCHEMAS/runtime-command-record.schema.json"
  local out_fix="$ONTARCH_REGISTRY/fixtures/command-envelope-valid.json"
  local sess_fix="$ONTARCH_REGISTRY/fixtures/runtime-command-record-valid.json"
  local profile_fix="$ONTARCH_REGISTRY/fixtures/profile-runtime-state-home.toml"
  ontarch_info "runtime contracts (schemas present + fixtures)"
  local sfail=0
  [ -f "$out_schema" ] || { ontarch_err "missing $out_schema"; sfail=1; }
  [ -f "$sess_schema" ] || { ontarch_err "missing $sess_schema"; sfail=1; }
  if [ -f "$out_fix" ]; then
    jq -e '.schema_version == "0.1.0" and .command and (.diagnostics | type == "array")' "$out_fix" >/dev/null \
      || { ontarch_err "command-envelope fixture missing required fields"; sfail=1; }
    printf '  %sok%s  fixtures/command-envelope-valid.json\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "missing $out_fix"
    sfail=1
  fi
  if [ -f "$sess_fix" ]; then
    jq -e '.schema_version == "0.1.0" and .record_kind == "command_execution" and .session_id and .execution.outcome' "$sess_fix" >/dev/null \
      || { ontarch_err "runtime-command-record fixture missing required fields"; sfail=1; }
    printf '  %sok%s  fixtures/runtime-command-record-valid.json\n' "$_C_GREEN" "$_C_RESET"
  else
    ontarch_err "missing $sess_fix"
    sfail=1
  fi
  if [ -f "$profile_fix" ]; then
    local full rec
    full="$(ontarch_descriptor_json "$profile_fix")"
    rec="$(ontarch_profile_record "$full")"
    if jq -e '.session_state_home == "/tmp/takogami-sessions-fixture"' <<<"$rec" >/dev/null; then
      printf '  %sok%s  fixtures/profile-runtime-state-home.toml (session_state_home projected)\n' "$_C_GREEN" "$_C_RESET"
    else
      ontarch_err "profile runtime fixture: session_state_home not projected"
      sfail=1
    fi
  else
    ontarch_err "missing $profile_fix"
    sfail=1
  fi
  [ "$sfail" -eq 0 ] || fail=1
}

_validate_manifest() {
  local schema="$ONTARCH_SCHEMAS/manifest.schema.json"
  local fixture="$ONTARCH_REGISTRY/fixtures/example-manifest.json"
  local generated="$ONTARCH_REGISTRY/manifest.json"
  [ -f "$schema" ] || ontarch_die "missing schema: $schema"

  ontarch_info "manifests (vs schemas/manifest.schema.json)"
  local mfail=0

  if [ -f "$fixture" ]; then
    if _check_manifest_doc "fixture" "$(cat "$fixture")"; then
      printf '  %sok%s  fixtures/example-manifest.json\n' "$_C_GREEN" "$_C_RESET"
    else
      mfail=1
    fi
  else
    ontarch_err "manifest fixture missing: $fixture"
    mfail=1
  fi

  local archived_fixture="$ONTARCH_REGISTRY/fixtures/example-manifest-archived.json"
  if [ -f "$archived_fixture" ]; then
    if _check_manifest_doc "archived-fixture" "$(cat "$archived_fixture")"; then
      printf '  %sok%s  fixtures/example-manifest-archived.json\n' "$_C_GREEN" "$_C_RESET"
    else
      mfail=1
    fi
  fi

  if [ -f "$generated" ]; then
    if _check_manifest_doc "registry/manifest.json" "$(cat "$generated")"; then
      printf '  %sok%s  registry/manifest.json (workflow=%s)\n' \
        "$_C_GREEN" "$_C_RESET" "$(jq -r '.workflow' "$generated")"
    else
      mfail=1
    fi
  else
    ontarch_warn "registry/manifest.json absent — run 'moon run ontarch:sync' (or scan) first"
  fi

  [ "$mfail" -eq 0 ] || fail=1
}

_validate_graph() {
  local schema="$ONTARCH_GRAPHS/edges.schema.json"
  local graph="$ONTARCH_REGISTRY/graph.json"

  [ -f "$schema" ] || ontarch_die "missing schema: $schema"
  [ -f "$graph" ]  || { ontarch_warn "graph.json absent — run 'moon run ontarch:sync' first"; return 0; }

  ontarch_info "graph (vs graphs/edges.schema.json)"
  local gfail=0

  # required top-level keys
  jq -e 'has("nodes") and has("edges")' "$graph" >/dev/null \
    || { ontarch_err "graph: missing required 'nodes' or 'edges'"; gfail=1; }

  # node kind enum
  local node_kinds
  node_kinds="$(jq -r '.properties.nodes.items.properties.kind.enum[]' "$schema")"
  for k in $(jq -r '.nodes[].kind' "$graph" | sort -u); do
    echo "$node_kinds" | grep -qx "$k" \
      || { ontarch_err "graph: node kind '$k' not in schema enum"; gfail=1; }
  done

  # edge rel enum
  local edge_rels
  edge_rels="$(jq -r '.properties.edges.items.properties.rel.enum[]' "$schema")"
  for r in $(jq -r '.edges[].rel' "$graph" | sort -u); do
    echo "$edge_rels" | grep -qx "$r" \
      || { ontarch_err "graph: edge rel '$r' not in schema enum"; gfail=1; }
  done

  # each edge endpoint must reference an existing node
  local dangling
  dangling="$(jq -r '
    [.nodes[].id] as $ids |
    (.edges | map(.from) + map(.to)) |
    map(select(. as $e | $ids | index($e) | not)) | unique | .[]
  ' "$graph" 2>/dev/null)"
  if [ -n "$dangling" ]; then
    ontarch_err "graph: dangling edge endpoints: $dangling"
    gfail=1
  fi

  local nn en
  nn=$(jq -r '.nodes | length' "$graph")
  en=$(jq -r '.edges | length' "$graph")

  if [ "$gfail" -eq 0 ]; then
    printf '  %sok%s  graph.json (%s nodes, %s edges) — all endpoints resolve\n' \
      "$_C_GREEN" "$_C_RESET" "$nn" "$en"
  else
    fail=1
  fi
}

main() {
  _validate_descriptors
  _validate_policies
  _validate_profiles
  _validate_skills
  _selfcheck_skillspector_gate
  _selfcheck_skill_scan_gate
  _selfcheck_policy_enforcement_shape
  _selfcheck_routing_projection
  _selfcheck_routing_schema
  _selfcheck_registry_generation
  _validate_scan
  _validate_bin_inventory
  _validate_manifest
  _selfcheck_manifest_retention
  _selfcheck_manifest_archive_reason
  _validate_runtime_schemas
  _validate_graph
  if [ "$fail" -eq 0 ]; then
    ontarch_ok "ontarch validate: PASS"
  else
    ontarch_err "ontarch validate: FAIL"
  fi
  exit "$fail"
}

main "$@"
