#!/usr/bin/env bash
# ontarch sync — generate the registry from descriptors, policies, and the .agents layer.
# Reads sources (descriptors/policies/tools.json/.agents) and writes only generated output
# under registry/ (and .agents/tools/local-toolkit.yml). Agent-safe: no
# install, no secret read, no dotfile edit.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/descriptor.sh
source "$_self/../lib/descriptor.sh"
# shellcheck source=../lib/registry.sh
source "$_self/../lib/registry.sh"

ontarch_require_jq
mkdir -p "$ONTARCH_REGISTRY"

ontarch_info "ontarch sync — generating registry"

ontarch_emit_units    > "$ONTARCH_REGISTRY/units.json"
ontarch_emit_skills   > "$ONTARCH_REGISTRY/skills.json"
ontarch_emit_profiles > "$ONTARCH_REGISTRY/profiles.json"
ontarch_emit_policies > "$ONTARCH_REGISTRY/policies.json"

u=$(jq -r '.summary.total' "$ONTARCH_REGISTRY/units.json")
p=$(jq -r '.policies | length' "$ONTARCH_REGISTRY/policies.json")
s=$(jq -r '.skills | length' "$ONTARCH_REGISTRY/skills.json")
pr=$(jq -r '.profiles | length' "$ONTARCH_REGISTRY/profiles.json")

ontarch_ok "units.json    ($u units)"
ontarch_ok "policies.json ($p policies)"
ontarch_ok "skills.json   ($s skills)"
ontarch_ok "profiles.json ($pr profiles)"

# Graph: derive relationships from units + policies (must run after units/policies are written).
if ontarch_emit_graph > "$ONTARCH_REGISTRY/graph.json" 2>/dev/null; then
  gn=$(jq -r '.nodes | length' "$ONTARCH_REGISTRY/graph.json")
  ge=$(jq -r '.edges | length' "$ONTARCH_REGISTRY/graph.json")
  ontarch_emit_graph_dot < "$ONTARCH_REGISTRY/graph.json" > "$ONTARCH_REGISTRY/graph.dot"
  ontarch_ok "graph.json    ($gn nodes, $ge edges)"
  ontarch_ok "graph.dot     -> registry/graph.dot"
else
  ontarch_warn "graph not generated (units.json or policies.json missing)"
fi

if [ -f "$ONTARCH_REGISTRY/tools.json" ]; then
  t=$(jq -r '.summary.total' "$ONTARCH_REGISTRY/tools.json" 2>/dev/null || echo "?")
  ontarch_info "tools.json present ($t tools — produced by 'panoply doctor')"
else
  ontarch_warn "tools.json absent — run 'panoply doctor' (or 'moon run panoply:doctor') to produce it"
fi

# .agents/ navigation view: the local toolkit list (present/missing/candidate/deprecated).
if [ -f "$ONTARCH_REGISTRY/tools.json" ]; then
  mkdir -p "$AGENTS_HOME/tools"
  ontarch_emit_local_toolkit > "$AGENTS_HOME/tools/local-toolkit.yml" \
    && ontarch_ok "local-toolkit.yml ($(grep -c '^  - ' "$AGENTS_HOME/tools/local-toolkit.yml") tools) -> .agents/tools/"
fi

# Manifest beside generated registry outputs.
_sync_outputs=(units.json skills.json profiles.json policies.json)
[ -f "$ONTARCH_REGISTRY/graph.json" ] && _sync_outputs+=(graph.json graph.dot)
ontarch_emit_manifest \
  --id "ontarch-sync-$(date -u +%Y%m%d-%H%M%S)" \
  --workflow "ontarch-sync" \
  --source "descriptors+policies+profiles+skills" \
  --tool "ontarch" \
  --retention "review-before-delete" \
  --notes "Generated by ontarch sync; host-specific registry outputs." \
  "${_sync_outputs[@]}" > "$ONTARCH_REGISTRY/manifest.json"
ontarch_ok "manifest.json  -> registry/manifest.json"
