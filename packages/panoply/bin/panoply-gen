#!/usr/bin/env bash
# panoply gen — derive install artifacts (Brewfile, mise block) from the manifest.
# Pure stdout, dry-run, read-only — agent-safe. Never installs or writes outside stdout.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/manifest.sh
source "$_self/../lib/manifest.sh"
# shellcheck source=../lib/generate.sh
source "$_self/../lib/generate.sh"

usage() {
  cat <<EOF
panoply gen — derive install artifacts from the manifest (dry-run, stdout only)

usage: panoply gen <artifact> [flags]

artifacts:
  brewfile [--check] [--missing] [--defaults]   emit a Brewfile; --check diffs vs config/Brewfile
  mise                                          emit a mise [tools] block (commented runtimes)

flags (brewfile):
  --check       compare generated output to config/Brewfile; exit non-zero on drift
  --missing     only tools not currently detected on this host
  --defaults    only module-default tools (default = true)
EOF
}

main() {
  local artifact="${1:-}"; shift || true
  case "$artifact" in
    brewfile)
      for a in "$@"; do [ "$a" = "--check" ] && exec_check=1; done
      if [ "${exec_check:-0}" = "1" ]; then
        panoply_gen_brewfile_check
      else
        panoply_gen_brewfile "$@"
      fi
      ;;
    mise)        panoply_gen_mise ;;
    help|-h|--help|"") usage ;;
    *) panoply_err "unknown artifact: $artifact"; echo; usage; exit 1 ;;
  esac
}

main "$@"
