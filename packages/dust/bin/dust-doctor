#!/usr/bin/env bash
# dust doctor — detect Dust tools, print a readiness report, write archon registry.
# Read-only and agent-safe.
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/manifest.sh
source "$_self/../lib/manifest.sh"

_json_escape() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'; }

total=0; installed=0; missing=0; missing_default=0
json_tools=""
current_module=""

write_json=1
[ "${1:-}" = "--no-write" ] && write_json=0

dust_info "Dust readiness (manifest v$(dust_manifest_version))"
echo

# shellcheck disable=SC2034  # fields bound positionally; not all used here
while IFS=$'\037' read -r module id def brew detect agent_safe alts purpose; do
  [ -n "$id" ] || continue
  if [ "$module" != "$current_module" ]; then
    [ -n "$current_module" ] && echo
    printf '%s%s%s\n' "$_C_BOLD" "$module" "$_C_RESET"
    current_module="$module"
  fi
  total=$((total + 1))
  if dust_detect "$detect"; then
    case "$detect" in
      */*) ver="installed" ;;   # path-detected (e.g. sourced plugin) — no --version
      *) ver="$(dust_version "$detect")" ;;
    esac
    installed=$((installed + 1))
    printf '  %sok%s  %-14s %s%s%s\n' "$_C_GREEN" "$_C_RESET" "$id" "$_C_DIM" "$ver" "$_C_RESET"
    is_installed=true
  else
    missing=$((missing + 1))
    ver=""
    if [ "$def" = "true" ]; then
      missing_default=$((missing_default + 1))
      printf '  %smiss%s %-14s %s(default, %s)%s\n' "$_C_RED" "$_C_RESET" "$id" "$_C_DIM" "${purpose}" "$_C_RESET"
    else
      printf '  %s--%s   %-14s %s(optional, %s)%s\n' "$_C_YELLOW" "$_C_RESET" "$id" "$_C_DIM" "${purpose}" "$_C_RESET"
    fi
    is_installed=false
  fi
  obj=$(printf '{"module":"%s","id":"%s","installed":%s,"default":%s,"agent_safe":%s,"detect":"%s","brew":"%s","version":"%s"}' \
    "$module" "$id" "$is_installed" "$def" "$agent_safe" "$detect" "$brew" "$(_json_escape "$ver")")
  if [ -z "$json_tools" ]; then json_tools="$obj"; else json_tools="$json_tools,$obj"; fi
done < <(dust_manifest_tsv)

echo
dust_info "installed $installed/$total  ·  missing $missing  ·  missing defaults $missing_default"

if [ "$write_json" = "1" ]; then
  mkdir -p "$ARCHON_REGISTRY"
  out="$ARCHON_REGISTRY/tools.json"
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  {
    printf '{\n'
    printf '  "generated_at": "%s",\n' "$ts"
    printf '  "manifest_version": "%s",\n' "$(dust_manifest_version)"
    printf '  "host": "%s",\n' "$(_json_escape "$(uname -sm)")"
    printf '  "summary": {"total":%s,"installed":%s,"missing":%s,"missing_default":%s},\n' \
      "$total" "$installed" "$missing" "$missing_default"
    printf '  "tools": [%s]\n' "$json_tools"
    printf '}\n'
  } > "$out"
  dust_ok "wrote $out"
fi

# ── secrets rail assertion (read-only; agent-safe) ───────────────────────────
# Asserts the no_secret_read gate is intact: manifest flags + policy gate + a live
# guard self-test. Never invokes pass/age/sops; only checks config and the guard.
echo
dust_info "secrets rail (no_secret_read gate)"
policy="$ARCHON_PKG/policies/dust.agent.policy.toml"
rail_fail=0

# agent_safe value for a manifest tool id (field 6), or MISSING.
_agent_safe_of() {
  dust_manifest_tsv | awk -F'\037' -v id="$1" '$2==id {print $6; f=1} END{if(!f) print "MISSING"}'
}

# 1) every policy-blocked secret tool must be agent_safe = false in the manifest.
if [ -f "$policy" ]; then
  block_tools="$(grep -E '^[[:space:]]*block_tools[[:space:]]*=' "$policy" | sed -E 's/.*\[(.*)\].*/\1/; s/[",]/ /g')"
else
  block_tools=""
fi
[ -n "$block_tools" ] || { printf '  %sxx%s  policy        block_tools missing (or policy missing)\n' "$_C_RED" "$_C_RESET"; rail_fail=1; }
for t in $block_tools; do
  as="$(_agent_safe_of "$t")"
  if [ "$as" = "false" ]; then
    printf '  %sok%s  %-14s agent_safe=false\n' "$_C_GREEN" "$_C_RESET" "$t"
  else
    printf '  %sxx%s  %-14s agent_safe=%s (must be false)\n' "$_C_RED" "$_C_RESET" "$t" "$as"
    rail_fail=1
  fi
done

# 2) policy must declare no_secret_read = true.
if [ -f "$policy" ] && grep -Eq '^[[:space:]]*no_secret_read[[:space:]]*=[[:space:]]*true' "$policy"; then
  printf '  %sok%s  policy        no_secret_read = true\n' "$_C_GREEN" "$_C_RESET"
else
  printf '  %sxx%s  policy        no_secret_read not true (or policy missing)\n' "$_C_RED" "$_C_RESET"
  rail_fail=1
fi

# 3) live guard self-test: under DUST_AGENT=1 the secret-read guard must exit 13.
( export DUST_AGENT=1; dust_require_secret_access pass ) >/dev/null 2>&1
guard_rc=$?
if [ "$guard_rc" -eq 13 ]; then
  printf '  %sok%s  guard         DUST_AGENT=1 blocks secret read (exit 13)\n' "$_C_GREEN" "$_C_RESET"
else
  printf '  %sxx%s  guard         DUST_AGENT=1 did not block (exit %s, expected 13)\n' "$_C_RED" "$_C_RESET" "$guard_rc"
  rail_fail=1
fi

if [ "$rail_fail" -eq 0 ]; then
  dust_ok "secrets rail: ENFORCED"
else
  dust_err "secrets rail: DRIFT — secret material could reach agent context"
fi

exit "$rail_fail"
