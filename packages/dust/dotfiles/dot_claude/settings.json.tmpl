{{- /*
  ~/.claude/settings.json — managed by chezmoi (WfOS). Profile: {{ .profile }}.
  Renders the RTK output-compression hook for Claude Code ONLY when the active profile enables
  rtk (.chezmoidata/profiles.toml `rtk`). RTK is the recommended-default compressor and is
  SWAPPABLE: a profile opts out by setting `rtk = false`, which drops the hooks block below.
  RTK INSTALL is owned by `dust bootstrap` / the manifest `agent` module; this template owns the
  per-profile wiring only. Draft (gateway_state: draft): chezmoi source, not applied to $HOME.
  The PreToolUse Bash hook is how RTK transparently rewrites a command (e.g. `git status` ->
  `rtk git status`) with zero token overhead; the exact hook entrypoint is confirmed against the
  installed rtk at bootstrap. See RTK-HOOK.md.
*/ -}}
{{- $p := index .profiles .profile -}}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "//": "GENERATED by chezmoi (WfOS) for profile {{ .profile }}. Do not hand-edit."{{ if $p.rtk }},
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude-pretooluse"
          }
        ]
      }
    ]
  }{{ end }}
}
