{{- $p := index .profiles .profile -}}
# ~/.config/wfos-secrets/env.sh — managed by chezmoi (WfOS). Profile: {{ .profile }}
# Secret REFERENCES only — values are resolved at chezmoi APPLY time, never stored in source.
# This target is in the `secrets` category; profiles that exclude it (agent-safe, headless-dev)
# never render this file at all, so `chezmoi diff` for them never resolves a reference.
{{- if $p.secrets }}
# pass vault (interactive): chezmoi's native `pass` function shells out to `pass show`
# at apply time only. The plaintext value is never written to the chezmoi source.
export WFOS_SAMPLE_TOKEN="{{ pass "wfos/sample" }}"
{{- else }}
# profile declares secrets = false: no secret references are resolved.
{{- end }}
