{{- $p := index .profiles .profile -}}
# ~/.zshrc — managed by chezmoi (WfOS). Profile: {{ .profile }} ({{ $p.description }})
# Thin entrypoint: sources the Dust native-substrate activation fragment (PATH, prompt, mise/direnv/
# zoxide/fzf init) and the profile-aware zsh plugin stack below. Every activation is guarded.

# chezmoi owns the zsh plugin layer; tell dust.zsh not to also source plugins, so the
# profile-aware fragment below is the single, authoritative source (avoids double-sourcing).
export DUST_PLUGINS_MANAGED=1

# Dust shell activation. Set DUST_HOME in ~/.zshenv if wfos is not under the
# suggested ~/Workstreams/Build/src/workspaces/wfos layout; bootstrap exports
# the resolved package path automatically.
: "${DUST_HOME:=${HOME}/Workstreams/Build/src/workspaces/wfos/packages/dust}"
if [ -f "$DUST_HOME/config/shell/dust.zsh" ]; then
  source "$DUST_HOME/config/shell/dust.zsh"
fi

# Profile-aware zsh plugin stack (guarded; missing plugin is harmless). See dot_config/zsh/.
[ -f "$HOME/.config/zsh/plugins.zsh" ] && source "$HOME/.config/zsh/plugins.zsh"
{{ if not $p.secrets }}
# profile declares secrets = false: no secret-backed env, no secret reads.
export WFOS_NO_SECRETS=1
{{ end -}}
{{- if eq .profile "agent-safe" }}
# agent-safe profile: minimal interactive surface, no remote-write helpers.
export WFOS_AGENT_SAFE=1
{{ end -}}
